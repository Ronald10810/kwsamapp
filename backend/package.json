{
  "name": "kwsa-backend",
  "version": "1.0.0",
  "description": "KWSA Cloud Console - Backend API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "data:staging:init": "tsx src/data/initStaging.ts",
    "data:import:market-centers": "tsx src/data/importMarketCentersCsv.ts",
    "data:import:teams": "tsx src/data/importTeamsCsv.ts",
    "data:import:associates": "tsx src/data/importAssociatesCsv.ts",
    "data:import:listings": "tsx src/data/importListingsCsv.ts",
    "data:import:transactions": "tsx src/data/importTransactionsCsv.ts",
    "data:transform:market-centers": "tsx src/data/transformMarketCenters.ts",
    "data:load:market-centers": "tsx src/data/loadMarketCenters.ts",
    "data:transform:teams": "tsx src/data/transformTeams.ts",
    "data:transform:associates": "tsx src/data/transformAssociates.ts",
    "data:transform:listings": "tsx src/data/transformListings.ts",
    "data:transform:transactions": "tsx src/data/transformTransactions.ts",
    "data:load:core": "tsx src/data/loadCore.ts",
    "data:validate": "tsx src/data/validateLoad.ts",
    "data:reconcile": "tsx src/data/reconcileReport.ts",
    "data:publish:legacy": "tsx src/data/publishLegacy.ts",
    "data:rollback:legacy": "tsx src/data/rollbackLegacy.ts",
    "data:run:batch": "tsx src/data/runBatch.ts",
    "data:run:batch:preserve": "cross-env PRESERVE_CORE_EDITS=true tsx src/data/runBatch.ts",
    "data:run:batch:refresh": "cross-env PRESERVE_CORE_EDITS=false tsx src/data/runBatch.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.0.0",
    "@prisma/client": "^5.7.1",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "pino": "^8.17.2",
    "pino-http": "^8.5.0",
    "prisma": "^5.7.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
